# Guardian Flow — Production Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# REQUIRED — Server will not start without these in production
# =============================================================================

# JWT secret for token signing (min 64 characters, random)
JWT_SECRET=

# Database connection (must not use default usernames/passwords)
DB_HOST=
DB_PORT=5432
DB_NAME=guardianflow
DB_USER=
DB_PASSWORD=
# DB_SSL=true                    # Enabled by default in production
# DB_SSL_REJECT_UNAUTHORIZED=true

# Frontend URL (for CORS — required in production)
FRONTEND_URL=https://your-domain.com

# =============================================================================
# REQUIRED — For full functionality
# =============================================================================

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=

# AI/ML
GEMINI_API_KEY=

# =============================================================================
# EMAIL — Required for password reset in production
# =============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Guardian Flow <noreply@your-domain.com>"

# =============================================================================
# OPTIONAL — Payment gateways (enable as needed)
# =============================================================================

STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# =============================================================================
# OPTIONAL — Redis (for multi-instance deployments)
# =============================================================================

# REDIS_URL=redis://redis:6379

# =============================================================================
# OPTIONAL — Secrets management
# =============================================================================

# SECRETS_PROVIDER=env           # Options: env, aws, gcp
# AWS_SECRET_NAME=guardian-flow/production
# AWS_REGION=us-east-1
# GCP_PROJECT_ID=your-project

# =============================================================================
# OPTIONAL — Monitoring
# =============================================================================

# SENTRY_DSN=
# SENTRY_SAMPLE_RATE=0.1

# =============================================================================
# OPTIONAL — Backups
# =============================================================================

# BACKUP_RETENTION_DAYS=7
# S3_BACKUP_BUCKET=your-backup-bucket

# =============================================================================
# OPTIONAL — Defaults shown
# =============================================================================

NODE_ENV=production
PORT=3001
LOG_LEVEL=info
