# Guardian Flow — Production Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# REQUIRED — Server will not start without these in production
# =============================================================================

# JWT secret for token signing (min 32 characters, random)
JWT_SECRET=

# Database connection
DB_HOST=
DB_PORT=5432
DB_NAME=guardianflow
DB_USER=
DB_PASSWORD=

# Frontend URL (for CORS)
FRONTEND_URL=https://your-domain.com

# =============================================================================
# REQUIRED — For full functionality
# =============================================================================

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=

# AI/ML
GEMINI_API_KEY=

# =============================================================================
# OPTIONAL — Payment gateways (enable as needed)
# =============================================================================

STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# =============================================================================
# OPTIONAL — Defaults shown
# =============================================================================

NODE_ENV=production
PORT=3001
LOG_LEVEL=info
PUBLIC_URL=https://your-api-domain.com
SERVER_URL=https://your-api-domain.com

# Supabase edge function server URL (used by analytics-ml-orchestrator)
# Must point to the Express server, not localhost
# SERVER_URL=https://your-api-domain.com
