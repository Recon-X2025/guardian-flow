# Environment Variables Template
# Copy this file to .env and fill in your values

# Backend API URL (required)
VITE_API_URL=http://localhost:3001

# Internal API (optional)
# INTERNAL_API_SECRET=

# Lovable AI (optional)
# LOVABLE_API_KEY=

# AI Provider (set to "openai" and supply OPENAI_API_KEY to enable real LLM responses)
# When AI_PROVIDER=mock (default), all AI features work with local keyword-based responses
# When AI_PROVIDER=openai, responses flow through GPT-4o via the OpenAI API
AI_PROVIDER=mock
# OPENAI_API_KEY=sk-...

# MongoDB Atlas Vector Search (set to "true" when using Atlas with a vector index)
# When false (default), vector search uses brute-force cosine similarity (works locally)
# When true, uses $vectorSearch aggregation for production-grade semantic search
# ATLAS_VECTOR_SEARCH=true

# Google Maps API (used for real driving distances in route optimization)
# When set, calculateDrivingTime() and optimizeRoute() use Google Maps Distance Matrix API
# When not set, haversine straight-line distance is used as fallback
# GOOGLE_MAPS_API_KEY=
# STRIPE_API_KEY=
# STRIPE_SECRET_KEY=

# ── Database Configuration ──────────────────────────────────────────────────
# Which database adapter to use (default: mongodb)
# Valid values: mongodb, postgresql
DB_ADAPTER=mongodb

# MongoDB connection (used when DB_ADAPTER=mongodb)
# MONGODB_URI=mongodb://localhost:27017/
# DB_NAME=guardianflow

# PostgreSQL connection (used when DB_ADAPTER=postgresql)
# POSTGRES_URI=postgres://user:password@localhost:5432/guardianflow

# Connection pool settings (shared)
# DB_POOL_MAX=20
# DB_POOL_CONNECT_TIMEOUT=5000
# DB_CONNECT_RETRIES=5
# DB_RETRY_DELAY_MS=3000

# ── PWA Push Notifications (VAPID) ─────────────────────────────────────────
# Generate with: node -e "const w=require('web-push'); const k=w.generateVAPIDKeys(); console.log(JSON.stringify(k))"
# Then install web-push: npm install web-push
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@yourcompany.com

# ── Tax Engine ──────────────────────────────────────────────────────────────
# Set TAX_PROVIDER to 'avalara', 'taxjar', or 'local' (default: local heuristic)
# TAX_PROVIDER=local

# Avalara AvaTax — https://developer.avalara.com/
# AVALARA_ACCOUNT_ID=
# AVALARA_LICENSE_KEY=
# AVALARA_ENV=sandbox   # or 'production'

# TaxJar — https://developers.taxjar.com/
# TAXJAR_API_KEY=
# TAXJAR_ENV=sandbox   # or 'production'

# ── Subscriptions / Recurring Billing ─────────────────────────────────────────
# Stripe keys (subscriptions module uses these when set)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # From Stripe dashboard → Webhooks

# ── IoT / MQTT ────────────────────────────────────────────────────────────────
# Set MQTT_BROKER_URL to connect to a real MQTT broker for live sensor telemetry.
# The server subscribes to: guardian-flow/telemetry/+ (one topic per device ID).
# Requires: npm install mqtt
# MQTT_BROKER_URL=mqtt://localhost:1883
