# Environment Variables Template
# Copy this file to .env and fill in your values

# Backend API URL (required)
VITE_API_URL=http://localhost:3001

# Internal API (optional)
# INTERNAL_API_SECRET=

# Lovable AI (optional)
# LOVABLE_API_KEY=

# AI Provider (optional - "mock" by default, "openai" when API key available)
AI_PROVIDER=mock
# OPENAI_API_KEY=

# Stripe (optional - for payment testing)
# STRIPE_API_KEY=
# STRIPE_SECRET_KEY=
