# Environment Variables Template
# Copy this file to .env and fill in your values

# Backend API URL (required)
VITE_API_URL=http://localhost:3001

# Internal API (optional)
# INTERNAL_API_SECRET=

# Lovable AI (optional)
# LOVABLE_API_KEY=

# AI Provider (optional - "mock" by default, "openai" when API key available)
AI_PROVIDER=mock
# OPENAI_API_KEY=

# Stripe (optional - for payment testing)
# STRIPE_API_KEY=
# STRIPE_SECRET_KEY=

# ── Database Configuration ──────────────────────────────────────────────────
# Which database adapter to use (default: mongodb)
# Valid values: mongodb, postgresql
DB_ADAPTER=mongodb

# MongoDB connection (used when DB_ADAPTER=mongodb)
# MONGODB_URI=mongodb://localhost:27017/
# DB_NAME=guardianflow

# PostgreSQL connection (used when DB_ADAPTER=postgresql)
# POSTGRES_URI=postgres://user:password@localhost:5432/guardianflow

# Connection pool settings (shared)
# DB_POOL_MAX=20
# DB_POOL_CONNECT_TIMEOUT=5000
# DB_CONNECT_RETRIES=5
# DB_RETRY_DELAY_MS=3000
